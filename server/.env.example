# Server Environment Variables

# The port the Express server will run on (default: 3001)
PORT=3001

# Google Cloud / Vertex AI Settings
# Your Google Cloud Project ID
GOOGLE_CLOUD_PROJECT="your-google-cloud-project-id"
# Your Google Cloud Location (e.g., europe-west1, us-central1)
GOOGLE_CLOUD_LOCATION="europe-west1"

# Gemini Models
# Model used for generating the images / inpainting
GEMINI_IMAGE_MODEL="gemini-2.5-flash-image"
# Model used for the multimodal real-time voice interaction
GEMINI_LIVE_MODEL="gemini-live-2.5-flash-native-audio"
